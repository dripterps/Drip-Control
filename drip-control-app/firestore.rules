rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone with the overlay link can read the current bag count
    // (that's what makes the public overlay page work, with no login).
    //
    // Writes require BOTH a signed-in user AND a matching email — just
    // checking "request.auth != null" is not enough, because Firebase's
    // client-side apiKey is public by design (it's bundled into the
    // deployed site), and Email/Password sign-up is reachable through the
    // SDK unless something blocks it. Without this email check, anyone
    // could call createUserWithEmailAndPassword() from the browser
    // console with your public config, sign themselves in, and edit your
    // bag count. Replace the email below with your real admin email —
    // the same one you created under Authentication -> Users.
    match /state/bagsTracker {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "YOUR_ADMIN_EMAIL@example.com";
    }
  }
}
